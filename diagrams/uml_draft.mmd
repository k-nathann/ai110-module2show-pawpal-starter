classDiagram
    class Owner {
        +str name
        +list pets
        +add_pet(pet) None
        +remove_pet(pet_name) None
        +get_all_tasks() list
    }

    class Pet {
        +str name
        +str species
        +int age
        +list tasks
        +add_task(task) None
        +remove_task(task_description) None
        +get_tasks() list
    }

    class Task {
        +str description
        +str scheduled_time
        +str frequency
        +bool completed
        +mark_complete() None
        +mark_incomplete() None
        +is_recurring() bool
    }

    class Scheduler {
        +Owner owner
        +sort_by_time(tasks) list
        +filter_tasks(tasks, pet_name, completed) list
        +detect_conflicts(tasks) list
        +get_today_schedule() list
    }

    Owner "1" --> "*" Pet : has
    Pet "1" --> "*" Task : has
    Scheduler --> Owner : organizes tasks for
